# Production environment contract for SafeMail.
#
# Copy to `.env.production` (gitignored) and fill in. This same set of variables
# is the deployment contract on ANY host — for the compose stack, pass it with
# `--env-file .env.production`; on a PaaS, set the same keys in its dashboard.
# Generate fresh secrets for production; do not reuse local-dev values.

# --- Core ---
DEBUG=false                       # MUST be false in production
COOKIE_SECURE=true                # HTTPS-only refresh cookie

# --- Datastores ---
# On the compose stack these point at the bundled services (hostnames postgres/
# redis). On a PaaS, use the managed add-on URLs it injects (the app normalizes
# postgres:// -> postgresql+asyncpg:// automatically).
POSTGRES_DB=safemail
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                # set a strong password
DATABASE_URL=postgresql+asyncpg://postgres:CHANGEME@postgres:5432/safemail
REDIS_URL=redis://redis:6379/0

# --- URLs (use your real domains) ---
FRONTEND_URL=https://app.example.com
GOOGLE_REDIRECT_URI=https://app.example.com/v1/auth/google/callback

# --- JWT keys (PEM contents, not file paths) ---
# Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the full PEM blocks (newlines preserved) here.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- Secrets (rotate for production) ---
# Generate FERNET_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ANTHROPIC_API_KEY=
SENDGRID_API_KEY=
FCM_SERVICE_ACCOUNT_JSON=

# --- Optional tuning ---
# WEB_CONCURRENCY=2               # uvicorn workers in the api container
# FRONTEND_PORT=80                # host port the frontend binds to
