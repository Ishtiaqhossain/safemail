DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openbark
REDIS_URL=redis://localhost:6379/0

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

ANTHROPIC_API_KEY=
SENDGRID_API_KEY=
FCM_SERVICE_ACCOUNT_JSON=

FRONTEND_URL=http://localhost:3000

# Local development convenience: enables /docs and relaxes the production
# secret-validation in config.py. Production MUST set DEBUG=false.
DEBUG=true
