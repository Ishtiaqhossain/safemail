DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openbark
REDIS_URL=redis://localhost:6379/0

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# Microsoft (Outlook / Microsoft 365) OAuth — optional; from a Microsoft Entra
# (Azure) app registration. Redirect URI must match the one registered there.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/v1/auth/oauth/microsoft/callback

ANTHROPIC_API_KEY=
SENDGRID_API_KEY=
FCM_SERVICE_ACCOUNT_JSON=

FRONTEND_URL=http://localhost:3000

# Local development convenience: enables /docs and relaxes the production
# secret-validation in config.py. Production MUST set DEBUG=false.
DEBUG=true

# ── Agentic self-monitoring ──────────────────────────────────────────────────
# Scheduled health probes + LLM remediation agent. See app/services/monitoring.py
# and app/services/remediation.py.
MONITORING_ENABLED=true
MONITORING_INTERVAL_MINUTES=10

# ── E2E testing seam (leave OFF except in the E2E test stack) ─────────────────
# When TRANSACTIONAL_EMAIL_ENABLED=false, all outbound email (verification, reset,
# alerts, digest) is skipped — used so tests never touch SendGrid.
TRANSACTIONAL_EMAIL_ENABLED=true
# The /v1/dev/* seed router mounts only when DEBUG=true AND E2E_SEED_ENABLED=true,
# and every request must send the X-E2E-Seed-Secret header. NEVER enable in prod.
E2E_SEED_ENABLED=false
E2E_SEED_SECRET=
# Let the remediation agent take bounded fix actions automatically (re-enqueue
# polling, reset a stuck connection). Off = diagnose-and-recommend only.
AUTO_REMEDIATION_ENABLED=false
# Destination for system-health alerts. Defaults to all admin parents if blank.
OPS_ALERT_EMAIL=
